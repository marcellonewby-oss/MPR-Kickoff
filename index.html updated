<script>
  function handleRegister() {
    const waiver = document.getElementById('waiverCheck');
    if (!waiver.checked) {
      waiver.closest('.form-group').style.borderColor = '#e05c5c';
      waiver.closest('.form-group').style.background = 'rgba(224,92,92,0.08)';
      alert('⚠️ Your whole team must acknowledge and agree to the waiver before registering.');
      return;
    }
    alert('Thanks for registering! We\'ll be in touch shortly to confirm your spot. ⚽🏆');
  }
  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
    if (!isOpen) item.classList.add('open');
  }
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.step-card, .prize-card, .format-card, .t-card, .faq-item').forEach(el => {
    el.style.opacity = '0'; el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity .5s ease, transform .5s ease, border-color .2s';
    observer.observe(el);
  });
</script>
