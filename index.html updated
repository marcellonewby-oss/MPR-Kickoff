<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MPR Kickoff – 7v7 Football Tournaments Madrid</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow+Condensed:wght@400;700;900&display=swap" rel="stylesheet"/>
<style>
  :root {
    --blue:   #3d8fb5;
    --blue2:  #2e7a9e;
    --navy:   #1a2744;
    --navy2:  #111c33;
    --gold:   #f5c21a;
    --gold2:  #d9a800;
    --white:  #ffffff;
    --muted:  #8a9ab8;
    --card:   #1e2f50;
    --border: rgba(61,143,181,0.22);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--navy2); color: var(--white); font-family: 'Barlow', sans-serif; overflow-x: hidden; }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 3rem;
    background: rgba(17,28,51,0.92); backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.75rem; letter-spacing: 3px; text-decoration: none; color: var(--white); }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { color: var(--muted); text-decoration: none; font-size: .82rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; transition: color .2s; }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta { background: var(--gold); color: var(--navy); padding: .55rem 1.4rem; border-radius: 4px; font-weight: 800; font-size: .82rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; transition: background .2s, transform .15s; }
  .nav-cta:hover { background: var(--gold2); transform: translateY(-1px); }

  .hero {
    min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 9rem 2rem 5rem; position: relative; overflow: hidden;
    background: linear-gradient(175deg, #0d1828 0%, #1a2744 50%, #0f1c35 100%);
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(61,143,181,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(61,143,181,0.07) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-glow { position: absolute; top: 20%; left: 50%; transform: translateX(-50%); width: 600px; height: 400px; background: radial-gradient(ellipse, rgba(61,143,181,0.18) 0%, transparent 70%); pointer-events: none; }
  .hero-glow2 { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 300px; background: radial-gradient(ellipse, rgba(245,194,26,0.08) 0%, transparent 70%); pointer-events: none; }

  .hero-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(245,194,26,0.12); border: 1px solid rgba(245,194,26,0.3); border-radius: 999px;
    padding: .4rem 1.2rem; font-size: .75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 2rem; position: relative; z-index: 1;
    animation: fadeUp .6s ease both;
  }
  .dot { width: 7px; height: 7px; background: var(--gold); border-radius: 50%; animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }
  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

  h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(4rem, 11vw, 8.5rem); line-height: .93; letter-spacing: 5px; position: relative; z-index: 1; animation: fadeUp .7s .1s ease both; }
  h1 .blue { color: var(--blue); }
  h1 .gold  { color: var(--gold); }

  .hero-sub { margin-top: 1.6rem; font-size: 1.1rem; color: var(--muted); max-width: 520px; line-height: 1.7; position: relative; z-index: 1; animation: fadeUp .7s .2s ease both; }
  .hero-location { margin-top: .8rem; font-size: .9rem; color: var(--blue); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; position: relative; z-index: 1; animation: fadeUp .7s .25s ease both; }
  .hero-location em { color: var(--muted); font-style: normal; font-weight: 400; letter-spacing: 0; text-transform: none; }

  .hero-actions { margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; position: relative; z-index: 1; animation: fadeUp .7s .3s ease both; }
  .btn-primary { background: var(--gold); color: var(--navy); padding: .9rem 2.4rem; border-radius: 5px; font-weight: 800; font-size: .95rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; border: none; cursor: pointer; transition: background .2s, transform .15s, box-shadow .2s; box-shadow: 0 0 30px rgba(245,194,26,0.25); }
  .btn-primary:hover { background: var(--gold2); transform: translateY(-2px); box-shadow: 0 0 45px rgba(245,194,26,0.4); }
  .btn-outline { background: transparent; color: var(--white); padding: .9rem 2.4rem; border-radius: 5px; font-weight: 700; font-size: .95rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; border: 1px solid rgba(255,255,255,0.2); cursor: pointer; transition: border-color .2s, color .2s, transform .15s; }
  .btn-outline:hover { border-color: var(--blue); color: var(--blue); transform: translateY(-2px); }

  .scroll-hint { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: .4rem; font-size: .72rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; z-index: 1; animation: fadeUp .7s .5s ease both; }
  .scroll-arrow { width: 1px; height: 36px; background: linear-gradient(var(--blue), transparent); margin: 0 auto; animation: scrollPulse 1.8s ease infinite; }
  @keyframes scrollPulse { 0%,100%{opacity:.3;transform:scaleY(.7)} 50%{opacity:1;transform:scaleY(1)} }

  .stats-strip { background: var(--navy); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 2.8rem 3rem; display: grid; grid-template-columns: repeat(4,1fr); text-align: center; }
  .stat-item { border-right: 1px solid var(--border); padding: 0 1.5rem; }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 3.8rem; line-height: 1; color: var(--gold); }
  .stat-label { font-size: .75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 2px; margin-top: .3rem; }

  .section-wrap { padding: 6rem 3rem; max-width: 1160px; margin: 0 auto; }
  .section-tag { font-size: .72rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--blue); margin-bottom: .8rem; display: block; }
  h2 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.4rem,4vw,3.5rem); letter-spacing: 2px; line-height: 1.05; margin-bottom: .8rem; }
  .section-intro { color: var(--muted); font-size: 1rem; max-width: 560px; line-height: 1.75; margin-bottom: 3rem; }

  .steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .step-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 2rem 1.8rem; position: relative; overflow: hidden; transition: transform .2s, border-color .2s; }
  .step-card:hover { transform: translateY(-5px); border-color: var(--blue); }
  .step-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--blue), var(--gold)); opacity: 0; transition: opacity .2s; }
  .step-card:hover::before { opacity: 1; }
  .step-num { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; line-height: 1; color: rgba(61,143,181,0.1); position: absolute; top: .5rem; right: 1rem; }
  .step-icon { font-size: 2rem; margin-bottom: 1rem; }
  .step-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.25rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; margin-bottom: .6rem; }
  .step-card p { font-size: .9rem; color: var(--muted); line-height: 1.65; }

  .prizes-bg { background: var(--navy); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .prize-grid { display: grid; grid-template-columns: 1fr 1.35fr 1fr; gap: 1.5rem; align-items: end; }
  .prize-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; text-align: center; padding: 2.2rem 1.5rem; transition: transform .2s; }
  .prize-card:hover { transform: translateY(-5px); }
  .prize-card.gold-card { background: linear-gradient(160deg, #1e2f50 0%, #162040 100%); border-color: var(--gold); padding: 3rem 1.5rem; box-shadow: 0 0 60px rgba(245,194,26,0.12); }
  .prize-medal { font-size: 2.6rem; margin-bottom: .8rem; }
  .prize-place { font-size: .72rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: .5rem; }
  .prize-amt { font-family: 'Bebas Neue', sans-serif; font-size: 3.5rem; color: var(--blue); line-height: 1; }
  .prize-card.gold-card .prize-amt { font-size: 5rem; color: var(--gold); }
  .prize-note { font-size: .85rem; color: var(--muted); margin-top: .5rem; }

  .format-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .format-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; transition: border-color .2s; }
  .format-card:hover { border-color: var(--gold); }
  .format-icon { font-size: 1.8rem; margin-bottom: 1rem; }
  .format-card h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 1.2rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; margin-bottom: .9rem; }
  .flist { list-style: none; }
  .flist li { font-size: .9rem; color: var(--muted); padding: .45rem 0; display: flex; align-items: flex-start; gap: .7rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .flist li:last-child { border-bottom: none; }
  .flist li::before { content: '▸'; color: var(--blue); font-size: .8rem; margin-top: .1rem; flex-shrink: 0; }

  .past-bg { background: var(--navy); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .tournament-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .t-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: transform .2s, border-color .2s; }
  .t-card:hover { transform: translateY(-5px); border-color: var(--blue); }
  .t-card-header { background: linear-gradient(135deg, var(--navy) 0%, #233060 100%); padding: 1.5rem; border-bottom: 1px solid var(--border); position: relative; }
  .t-edition { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 2px; color: var(--gold); }
  .t-date { font-size: .78rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-top: .2rem; }
  .t-badge { position: absolute; top: 1.2rem; right: 1.2rem; background: rgba(245,194,26,0.15); border: 1px solid rgba(245,194,26,0.4); border-radius: 999px; padding: .25rem .7rem; font-size: .7rem; font-weight: 700; color: var(--gold); letter-spacing: 1px; text-transform: uppercase; }
  .t-card-body { padding: 1.4rem; }
  .t-row { display: flex; justify-content: space-between; align-items: center; padding: .5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .t-row:last-child { border-bottom: none; }
  .t-key { font-size: .78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
  .t-val { font-size: .9rem; font-weight: 700; color: var(--white); }
  .t-winner { color: var(--gold); }

  .reg-section { background: linear-gradient(135deg, #0f1c35 0%, #1a2744 50%, #0f1c35 100%); border-top: 1px solid var(--border); }
  .reg-inner { max-width: 680px; margin: 0 auto; text-align: center; padding: 6rem 2rem; }
  .reg-inner p { color: var(--muted); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2.5rem; }
  .reg-form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: .4rem; }
  label { font-size: .78rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); }
  input, select { background: var(--card); border: 1px solid var(--border); color: var(--white); padding: .75rem 1rem; border-radius: 6px; font-family: 'Barlow', sans-serif; font-size: .95rem; outline: none; transition: border-color .2s; width: 100%; }
  input::placeholder { color: rgba(138,154,184,0.5); }
  input:focus, select:focus { border-color: var(--blue); }
  select option { background: var(--navy); }
  .submit-btn { background: var(--gold); color: var(--navy); padding: 1rem; border-radius: 6px; border: none; cursor: pointer; font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 2px; transition: background .2s, transform .15s, box-shadow .2s; box-shadow: 0 0 30px rgba(245,194,26,0.2); margin-top: .5rem; width: 100%; }
  .submit-btn:hover { background: var(--gold2); transform: translateY(-2px); box-shadow: 0 0 45px rgba(245,194,26,0.4); }

  .faq-list { display: flex; flex-direction: column; gap: .8rem; max-width: 720px; }
  .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .faq-q { width: 100%; background: none; border: none; color: var(--white); padding: 1.2rem 1.5rem; text-align: left; cursor: pointer; font-family: 'Barlow', sans-serif; font-size: .95rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; gap: 1rem; transition: color .2s; }
  .faq-q:hover { color: var(--gold); }
  .faq-icon { color: var(--blue); font-size: 1.2rem; transition: transform .3s; flex-shrink: 0; }
  .faq-a { display: none; padding: 0 1.5rem 1.2rem; font-size: .9rem; color: var(--muted); line-height: 1.7; }
  .faq-item.open .faq-icon { transform: rotate(45deg); color: var(--gold); }
  .faq-item.open .faq-a { display: block; }

  footer { background: var(--navy2); border-top: 1px solid var(--border); padding: 3rem; text-align: center; }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 4px; color: var(--white); margin-bottom: .5rem; }
  .footer-logo span { color: var(--gold); }
  .footer-tagline { font-size: .85rem; color: var(--muted); margin-bottom: 1.5rem; }
  .footer-links { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .footer-links a { font-size: .8rem; color: var(--muted); text-decoration: none; text-transform: uppercase; letter-spacing: 1px; transition: color .2s; }
  .footer-links a:hover { color: var(--gold); }
  .footer-copy { font-size: .75rem; color: rgba(138,154,184,0.5); }

  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .stats-strip { grid-template-columns: 1fr 1fr; }
    .stat-item:nth-child(2) { border-right: none; }
    .steps, .format-grid, .tournament-cards, .prize-grid { grid-template-columns: 1fr; }
    .prize-card.gold-card { order: -1; }
    .form-row { grid-template-columns: 1fr; }
    .section-wrap { padding: 4rem 1.5rem; }
  }
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#"><span>MPR</span> KICKOFF</a>
  <ul class="nav-links">
    <li><a href="#how">Format</a></li>
    <li><a href="#prizes">Prizes</a></li>
    <li><a href="#history">History</a></li>
    <li><a href="#faq">FAQ</a></li>
  </ul>
